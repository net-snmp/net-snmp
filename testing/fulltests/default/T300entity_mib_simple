#!/bin/sh

. ../support/simple_eval_tools.sh

HEADER ENTITY-MIB entPhysicalTable and related tables

SKIPIFNOT USING_HARDWARE_ENTITY_ENTPHYSICALTABLE_MODULE

#
# Begin test
#

. ./Sv2cconfig

STARTAGENT

# entPhysicalDescr (column 2): at least one string-typed varbind must exist.
# On any real Linux system there is always at least a chassis entry.
CAPTURE "snmpwalk -On $SNMP_FLAGS -c testcommunity -v 2c $SNMP_TRANSPORT_SPEC:$SNMP_TEST_DEST$SNMP_SNMPD_PORT .1.3.6.1.2.1.47.1.1.1.1.2"
CHECKCOUNT atleastone "\.1\.3\.6\.1\.2\.1\.47\.1\.1\.1\.1\.2\."

# entPhysicalClass (column 5): at least one integer class value must exist.
CAPTURE "snmpwalk -On $SNMP_FLAGS -c testcommunity -v 2c $SNMP_TRANSPORT_SPEC:$SNMP_TEST_DEST$SNMP_SNMPD_PORT .1.3.6.1.2.1.47.1.1.1.1.5"
CHECKCOUNT atleastone "\.1\.3\.6\.1\.2\.1\.47\.1\.1\.1\.1\.5\."

# entPhysicalIsFRU (column 16): must return TruthValue (INTEGER 1 or 2).
CAPTURE "snmpwalk -On $SNMP_FLAGS -c testcommunity -v 2c $SNMP_TRANSPORT_SPEC:$SNMP_TEST_DEST$SNMP_SNMPD_PORT .1.3.6.1.2.1.47.1.1.1.1.16"
CHECKCOUNT atleastone "\.1\.3\.6\.1\.2\.1\.47\.1\.1\.1\.1\.16\."

# entPhysicalContainsTable (.47.1.3.3): at least one child relationship exists.
CAPTURE "snmpwalk -On $SNMP_FLAGS -c testcommunity -v 2c $SNMP_TRANSPORT_SPEC:$SNMP_TEST_DEST$SNMP_SNMPD_PORT .1.3.6.1.2.1.47.1.3.3"
CHECKCOUNT atleastone "\.1\.3\.6\.1\.2\.1\.47\.1\.3\.3\."

# entLastChangeTime (.47.1.4.1.0) must be a Timeticks scalar.
CAPTURE "snmpget -On $SNMP_FLAGS -c testcommunity -v 2c $SNMP_TRANSPORT_SPEC:$SNMP_TEST_DEST$SNMP_SNMPD_PORT .1.3.6.1.2.1.47.1.4.1.0"
CHECKORDIE ".1.3.6.1.2.1.47.1.4.1.0 = Timeticks:"

STOPAGENT

FINISHED
